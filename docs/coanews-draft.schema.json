{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aimax-004-v1-codex.vercel.app/coanews-draft.schema.json",
  "title": "COA NEWS article pending editor approval",
  "type": "object",
  "required": [
    "schema_version",
    "external_id",
    "status",
    "publish_allowed",
    "category",
    "title",
    "subtitles",
    "body_file",
    "thumbnail",
    "tags",
    "options",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "const": "coanews-draft/1.0" },
    "external_id": { "type": "string", "pattern": "^coa-[0-9]{8}-[a-z0-9]+$" },
    "status": { "const": "pending_editor_approval" },
    "publish_allowed": { "const": false },
    "category": { "$ref": "#/$defs/category" },
    "additional_categories": {
      "type": "array",
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/category" }
    },
    "scheduled_at": { "type": ["string", "null"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 180 },
    "subtitles": {
      "type": "array",
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1, "maxLength": 180 }
    },
    "reporter_email": { "type": ["string", "null"], "format": "email" },
    "body_file": { "const": "body.html" },
    "thumbnail_file": { "type": ["string", "null"] },
    "thumbnail": {
      "type": "object",
      "required": ["width", "height", "alt", "caption", "source"],
      "properties": {
        "width": { "anyOf": [{ "const": 800 }, { "type": "null" }] },
        "height": { "anyOf": [{ "const": 400 }, { "type": "null" }] },
        "alt": { "type": ["string", "null"] },
        "caption": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "source_url": { "type": ["string", "null"], "format": "uri" },
    "options": {
      "type": "object",
      "required": [
        "comments_enabled",
        "show_on_main",
        "show_as_headline",
        "article_type",
        "share_news",
        "share_policy_consent",
        "video_generation"
      ],
      "properties": {
        "comments_enabled": { "type": "boolean" },
        "show_on_main": { "type": "boolean" },
        "show_as_headline": { "type": "boolean" },
        "article_type": { "enum": ["normal", "advertorial"] },
        "share_news": { "type": "boolean" },
        "share_policy_consent": { "type": "boolean" },
        "video_generation": { "const": "disabled" }
      },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
