COLLECTOR_TIMEOUT=15
COLLECTOR_CONCURRENCY=4
COLLECTOR_MAX_PAGES_PER_SOURCE=10
COLLECTOR_EXPORT_DIR=exports

# ── 코아뉴스 키워드 파이프라인 (api/cron/*) ─────────────────────────
# 아래 값은 여기 채우지 말고 로컬 .env 및 Vercel 프로젝트 환경변수에만 설정하세요.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# 작업별 기본 모델. 허용값: gpt-5.4-nano, gpt-5-mini, gpt-5.4-mini
OPENAI_MODEL_CLASSIFY=gpt-5.4-nano
OPENAI_MODEL_SUGGEST=gpt-5-mini
OPENAI_MODEL_DRAFT=gpt-5-mini
OPENAI_MODEL_PREMIUM=gpt-5.4-mini
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SLACK_WEBHOOK_URL=
CRON_SECRET=

# ── VPS n8n ───────────────────────────────────────────────────────────────────
SERVER_IP=
N8N_USER=admin
N8N_PASSWORD=
N8N_BIND_HOST=0.0.0.0
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=
N8N_SECURE_COOKIE=false

# ── Vercel → n8n → Agent Reach runner ────────────────────────────────────────
AGENT_REACH_WEBHOOK_URL=
AGENT_REACH_WEBHOOK_SECRET=
AGENT_REACH_RUNNER_SECRET=
AGENT_REACH_RUNNER_HOST=0.0.0.0
AGENT_REACH_RUNNER_PORT=8787
AGENT_REACH_RUNNER_URL=http://host.docker.internal:8787/run

# ── Agent Reach VPS collector (scripts/agent-reach-collect.js) ────────────────
# Comma-separated sources: exa,rss,youtube,github
# Stable defaults. Add youtube after cookie setup and github after gh/GH_TOKEN authentication.
AGENT_REACH_SOURCES=exa,rss
AGENT_REACH_LIMIT_KEYWORDS=6
AGENT_REACH_CORE_KEYWORDS=4
AGENT_REACH_ROTATING_KEYWORDS=2
AGENT_REACH_EXA_RESULTS=5
AGENT_REACH_YOUTUBE_RESULTS=3
AGENT_REACH_GITHUB_RESULTS=5
AGENT_REACH_TIMEOUT_MS=45000
AGENT_REACH_JINA_ENRICH=false
# Feed format: Name|URL|category, separated by comma/semicolon/newline.
# Category is optional and must be one of ai_business,startup,policy.
AGENT_REACH_RSS_FEEDS=
