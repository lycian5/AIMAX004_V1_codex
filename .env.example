# Local and Vercel API settings
COLLECTOR_TIMEOUT=15
COLLECTOR_CONCURRENCY=4
COLLECTOR_MAX_PAGES_PER_SOURCE=10
COLLECTOR_EXPORT_DIR=exports

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_CLASSIFY=gpt-5.4-nano
OPENAI_MODEL_SUGGEST=gpt-5-mini
OPENAI_MODEL_DRAFT=gpt-5-mini
OPENAI_MODEL_PREMIUM=gpt-5.4-mini
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SLACK_WEBHOOK_URL=

# Authentication
CRON_SECRET=
DASHBOARD_PASSWORD=
# Optional: separate 32+ character secret for dashboard sessions.
DASHBOARD_SESSION_SECRET=

# Vercel base collector: broad, low-cost Naver/Google collection.
BASE_COLLECT_LIMIT_KEYWORDS=18
BASE_COLLECT_CORE_KEYWORDS=6
BASE_COLLECT_ROTATING_KEYWORDS=12

# Vercel to VPS/n8n Agent Reach trigger
AGENT_REACH_WEBHOOK_URL=
AGENT_REACH_WEBHOOK_SECRET=

# Agent Reach runner and VPS collector
AGENT_REACH_RUNNER_SECRET=
AGENT_REACH_RUNNER_HOST=0.0.0.0
AGENT_REACH_RUNNER_PORT=8787
AGENT_REACH_RUNNER_URL=http://host.docker.internal:8787/run
# Add youtube only after cookie setup and github only after gh/GH_TOKEN authentication.
AGENT_REACH_SOURCES=exa,official,rss
AGENT_REACH_LIMIT_KEYWORDS=54
AGENT_REACH_CORE_KEYWORDS=12
AGENT_REACH_ROTATING_KEYWORDS=42
AGENT_REACH_EXA_RESULTS=5
AGENT_REACH_OFFICIAL_RESULTS=3
AGENT_REACH_RSS_RESULTS=8
AGENT_REACH_YOUTUBE_RESULTS=3
AGENT_REACH_GITHUB_RESULTS=5
AGENT_REACH_TIMEOUT_MS=45000
AGENT_REACH_JINA_ENRICH=false
# Format: Name|URL|category, separated by comma, semicolon, or newline.
AGENT_REACH_RSS_FEEDS=

# Canonical VPS/n8n variables live in deploy/n8n/.env.example.
